# =========================================
# TDID E-Cert Application Configuration
# =========================================
# Copy this file to 'application.properties' and update the values marked with <...>

# Server Configuration
server.port=8080

# H2 Database Configuration (Development)
spring.datasource.url=jdbc:h2:mem:testdb
spring.datasource.driverClassName=org.h2.Driver
spring.datasource.username=sa
spring.datasource.password=password
spring.h2.console.enabled=true
spring.h2.console.path=/h2-console

# JPA Configuration
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect
spring.jpa.hibernate.ddl-auto=create-drop
spring.jpa.show-sql=true

# Application Name
spring.application.name=learn-javaspringboot

# OpenAPI / Swagger
springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.operationsSorter=method
springdoc.swagger-ui.tagsSorter=alpha

# JWT Configuration
# IMPORTANT: Change this to a strong random secret in production
jwt.secret=<YOUR_STRONG_SECRET_KEY_HERE>
jwt.expiration=86400000

# Email Configuration (SMTP)
# IMPORTANT: Update with your real SMTP credentials
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=<YOUR_EMAIL@gmail.com>
spring.mail.password=<YOUR_APP_PASSWORD_HERE>
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# Application email from
app.mail.from=noreply@tdid-ecert.com

# Disable CORS validation for development
spring.security.filter.order=-100
